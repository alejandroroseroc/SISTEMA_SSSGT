# Template de variables de entorno para staging/producción
# NO incluir valores reales en el repositorio
# Copiar este archivo como .env y completar los valores

DATABASE_URL=postgresql://[usuario]:[password]@[host]:5432/sgsst_prod

# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=[generar_secreto_seguro]

JWT_EXPIRES_IN=7d

FRONTEND_URL=https://[tu-app].vercel.app

PORT=3001

NODE_ENV=production
